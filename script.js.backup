// ── Palabras clave para detectar líquidos y excluirlos del buscador ──
const palabrasLiquido = [
    'liquido','gel','aerosol','cloro','lavandina','alcohol','amonia',
    'desinfectante','desengrasante','suavizante','detergente','doy pack',
    'jarabe','aceite','spray','lata','vinagre','creolina','atomizador',
    'botella','mini','siliconado','lysoform','glade','poett','flit',
    'lubricante','conc.','soda caustica','regulador'
];

const productosNoLiquidos = productosDB.filter(p =>
    !palabrasLiquido.some(pal => p.nombre.toLowerCase().includes(pal))
);

// ── Historial guardado en localStorage ──────────────────────
function cargarHistorial() {
    try {
        return JSON.parse(localStorage.getItem('famat_historial')) || [];
    } catch { return []; }
}

function guardarHistorial(lista) {
    try {
        localStorage.setItem('famat_historial', JSON.stringify(lista));
    } catch {}
}

// ── CATEGORÍAS DINÁMICAS ──────────────────────────────────────

let categoriaActual = 'producto';
let granelAgregados = [];

const productosPorKilo = [
    'bicarbonato', 'jabon en polvo', 'polvo limpiador', 'cloro granulado',
    'naftalina', 'soda caustica', 'absorvente de humedad', 'granulado',
    'clorado', 'kilo', 'x kilo', '(x kilo)'
];

function esCategoriaGranel(nombre) {
    return productosPorKilo.some(palabra => nombre.toLowerCase().includes(palabra));
}

function cambiarCategoria(categoria, btn) {
    categoriaActual = categoria;
    
    // Actualizar botones activos
    document.querySelectorAll('.btn-categoria').forEach(b => {
        b.classList.remove('btn-categoria--active');
    });
    btn.classList.add('btn-categoria--active');
    
    // Ocultar todas las secciones
    document.getElementById('seccion-producto').classList.remove('seccion-dinamica--visible');
    document.getElementById('seccion-liquido').classList.remove('seccion-dinamica--visible');
    document.getElementById('seccion-granel').classList.remove('seccion-dinamica--visible');
    
    // Mostrar la sección seleccionada
    document.getElementById(`seccion-${categoria}`).classList.add('seccion-dinamica--visible');
}

function agregarGranelSeleccionado() {
    const select = document.getElementById('granelSelect');
    const nombreProducto = select.value.trim();
    
    if (!nombreProducto) {
        alert('⚠️ Por favor, seleccioná un producto a granel');
        return;
    }
    
    const kilos = parseFloat(document.getElementById('granelKilos').value) || 1;
    
    if (kilos <= 0) {
        alert('⚠️ La cantidad de kilos debe ser mayor a 0');
        return;
    }
    
    const producto = {
        nombre: nombreProducto,
        kilos: kilos,
        id: Math.random()
    };
    
    granelAgregados.push(producto);
    mostrarGranelAgregados();
    
    select.value = '';
    document.getElementById('granelKilos').value = '1';
}

function mostrarGranelAgregados() {
    const contenedor = document.getElementById('granelAgregados');
    
    if (granelAgregados.length === 0) {
        contenedor.innerHTML = '';
        return;
    }
    
    contenedor.innerHTML = granelAgregados.map(item => `
        <div class="granel-item">
            <div class="granel-info">
                <div class="granel-nombre">${item.nombre}</div>
                <div class="granel-detalles">${item.kilos} kg</div>
            </div>
            <button class="btn-eliminar-liquido" onclick="eliminarGranel(${item.id})">✕ Eliminar</button>
        </div>
    `).join('');
}

function eliminarGranel(id) {
    granelAgregados = granelAgregados.filter(item => item.id !== id);
    mostrarGranelAgregados();
}

// ── Inicializar SELECT de Granel ────────────────────
function inicializarBuscadorGranel() {
    const select = document.getElementById('granelSelect');
    
    if (!select) return;
    
    // Llenar SELECT solo con productos de granel
    const productosGranel = productosDB.filter(p => esCategoriaGranel(p.nombre));
    
    productosGranel.forEach(producto => {
        const option = document.createElement('option');
        option.value = producto.nombre;
        option.textContent = producto.nombre;
        select.appendChild(option);
    });
}


// ── Inicialización ────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function () {
    mostrarProductos();
    mostrarLiquidos();
    inicializarBuscador();
    inicializarBuscadorGranel();
    mostrarHistorial();

    const liquidoSelect = document.getElementById('liquidoSelect');
    if (liquidoSelect) {
        liquidoSelect.addEventListener('change', function () {
            const filaAroma = document.getElementById('filaAroma');
            if (this.value === 'Perfume P/ropa al agua') {
                filaAroma.style.display = 'block';
                document.getElementById('aromaSelect').focus();
            } else {
                filaAroma.style.display = 'none';
                document.getElementById('aromaSelect').value = '';
            }
        });
    }
});

// ── Inicializar SELECT de Productos ──────────────────────
function inicializarBuscador() {
    const select = document.getElementById('productoSelect');
    
    if (!select) return;
    
    // Llenar SELECT con todos los productos
    productosNoLiquidos.forEach(producto => {
        const option = document.createElement('option');
        option.value = producto.nombre;
        option.textContent = producto.nombre;
        select.appendChild(option);
    });
    
    // Listener para detectar cambios
    select.addEventListener('change', function() {
        const nombre = this.value;
        if (!nombre) {
            document.getElementById('filakilos').style.display = 'none';
            document.getElementById('productoQty').value = '1';
            return;
        }
        
        const esXKilo = nombre.toLowerCase().includes('x kilo') || nombre.toLowerCase().includes('(x kilo)');
        const filakilos = document.getElementById('filakilos');
        const inputCantidad = document.getElementById('productoQty');
        
        if (esXKilo) {
            filakilos.style.display = 'block';
            inputCantidad.value = '1';
            document.getElementById('productoKilos').focus();
        } else {
            filakilos.style.display = 'none';
            inputCantidad.value = '1';
            inputCantidad.focus();
        }
    });
}

// ── Agregar / eliminar productos ──────────────────────────────
function agregarProductoSeleccionado() {
    const nombre = document.getElementById('productoSelect').value;
    if (!nombre) { alert('⚠️ Por favor, seleccioná un producto'); return; }

    const esXKilo = nombre.toLowerCase().includes('x kilo') || nombre.toLowerCase().includes('(x kilo)');
    let cantidad = null, kilos = null;

    if (esXKilo) {
        kilos = parseFloat(document.getElementById('productoKilos').value) || 0;
        if (kilos <= 0) { alert('⚠️ Por favor, ingresá una cantidad válida de kilos'); return; }
    } else {
        cantidad = parseInt(document.getElementById('productoQty').value) || 1;
    }

    productosAgregados.push({ id: Date.now(), nombre, cantidad, kilos });

    // Resetear campos
    document.getElementById('productoSelect').value = '';
    const inputQty = document.getElementById('productoQty');
    inputQty.value = '1';
    document.getElementById('filakilos').style.display = 'none';
    document.getElementById('productoKilos').value = '1';

    mostrarProductos();
}

function eliminarProducto(id) {
    productosAgregados = productosAgregados.filter(p => p.id !== id);
    mostrarProductos();
}

function mostrarProductos() {
    const container = document.getElementById('productosAgregados');
    if (productosAgregados.length === 0) {
        container.innerHTML = '<p style="color:#999;margin:0;">Sin productos agregados</p>';
        return;
    }
    container.innerHTML = productosAgregados.map(p => {
        const det = (p.kilos !== null && p.kilos > 0) ? `${p.kilos} kg` : `x${p.cantidad}`;
        return `<div class="producto-item">
            <div class="producto-info">
                <div class="producto-nombre">${p.nombre}</div>
                <div class="producto-detalles">${det}</div>
            </div>
            <button class="btn-eliminar-liquido" onclick="eliminarProducto(${p.id})">🗑️</button>
        </div>`;
    }).join('');
}

// ── Agregar / eliminar líquidos ───────────────────────────────
function agregarLiquidoNuevo() {
    const select = document.getElementById('liquidoSelect');
    let nombre   = select.value;
    const litros = parseFloat(document.getElementById('liquidoLitros').value);

    if (!nombre) { alert('⚠️ Por favor, seleccioná un líquido'); return; }

    if (nombre.includes('Perfume')) {
        const aroma = document.getElementById('aromaSelect').value;
        if (!aroma) { alert('⚠️ Por favor, seleccioná un aroma para el perfume'); return; }
        nombre = `${nombre} - ${aroma}`;
    }

    if (!litros || litros <= 0) { alert('⚠️ Por favor, ingresá una cantidad válida de litros'); return; }

    liquidosAgregados.push({ id: Date.now(), nombre, litros });

    select.value = '';
    document.getElementById('liquidoLitros').value = '1';
    document.getElementById('filaAroma').style.display = 'none';
    document.getElementById('aromaSelect').value = '';

    mostrarLiquidos();
}

function eliminarLiquido(id) {
    liquidosAgregados = liquidosAgregados.filter(l => l.id !== id);
    mostrarLiquidos();
}

function mostrarLiquidos() {
    const container = document.getElementById('liquidosAgregados');
    if (liquidosAgregados.length === 0) {
        container.innerHTML = '<p style="color:#999;margin:0;">Sin líquidos agregados</p>';
        return;
    }
    container.innerHTML = liquidosAgregados.map(l =>
        `<div class="liquido-item">
            <div class="liquido-info">
                <div class="liquido-nombre">${l.nombre}</div>
                <div class="liquido-detalles">${l.litros} L</div>
            </div>
            <button class="btn-eliminar-liquido" onclick="eliminarLiquido(${l.id})">🗑️</button>
        </div>`
    ).join('');
}

// ── Limpiar formulario ────────────────────────────────────────
function confirmarLimpiar() {
    if (productosAgregados.length === 0 && liquidosAgregados.length === 0) {
        limpiarFormulario();
        return;
    }
    if (confirm('¿Querés limpiar el formulario? Se borrarán los productos y líquidos cargados.')) {
        limpiarFormulario();
    }
}

function limpiarFormulario() {
    document.getElementById('cliente').value  = '';
    document.getElementById('entrega').value  = '';
    document.getElementById('notas').value    = '';
    document.getElementById('productoSelect').value = '';
    document.getElementById('granelSelect').value = '';

    const inputQty = document.getElementById('productoQty');
    inputQty.value = '1';

    document.getElementById('liquidoSelect').value = '';
    document.getElementById('liquidoLitros').value = '1';
    document.getElementById('aromaSelect').value   = '';
    document.getElementById('filakilos').style.display  = 'none';
    document.getElementById('filaAroma').style.display  = 'none';
    document.getElementById('productoKilos').value = '1';

    productosAgregados  = [];
    liquidosAgregados   = [];
    granelAgregados     = [];

    mostrarProductos();
    mostrarLiquidos();
    mostrarGranelAgregados();
    document.getElementById('cliente').focus();
}

// ── Copiar alias ──────────────────────────────────────────────
function copiarAlias() {
    const texto = 'FAMAT.PEDIDOS';
    navigator.clipboard.writeText(texto)
        .then(() => alert('✓ Alias copiado al portapapeles: ' + texto))
        .catch(() => alert('No se pudo copiar automáticamente. El alias es: ' + texto));
}

// ── Enviar pedido: guarda en Controlador y abre WA de aviso ──
function enviarPorWhatsApp() {
    const cliente = document.getElementById('cliente').value.trim();
    const entrega = document.getElementById('entrega').value;
    const notas   = document.getElementById('notas').value.trim();

    if (!cliente) { alert('⚠️ Por favor, ingresá el nombre del cliente'); return; }
    if (productosAgregados.length === 0 && liquidosAgregados.length === 0 && granelAgregados.length === 0) {
        alert('⚠️ Por favor, agregá al menos un producto, líquido o granel'); return;
    }
    if (!entrega) { alert('⚠️ Por favor, seleccioná una fecha de entrega'); return; }

    const fechaFormateada = new Date(entrega + 'T12:00:00').toLocaleDateString('es-AR');

    // 1️⃣ Guardar en localStorage — el Controlador lo levanta automáticamente
    const STORAGE_KEY = 'famat_pedidos';
    let pedidos = [];
    try { pedidos = JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; } catch {}

    pedidos.unshift({
        id: Date.now(),
        fechaCreacion: new Date().toLocaleDateString('es-AR'),
        cliente,
        productos: JSON.parse(JSON.stringify(productosAgregados)),
        liquidos:  JSON.parse(JSON.stringify(liquidosAgregados)),
        granel:    JSON.parse(JSON.stringify(granelAgregados)),
        entrega:   fechaFormateada,
        notas,
        estado:    'pendiente'
    });

    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(pedidos)); }
    catch { alert('Error al guardar el pedido. Revisá el almacenamiento.'); return; }

    // 2️⃣ Abrir WhatsApp con mensaje de aviso al número del controlador
    const msgWA = `⚠️ Nuevo pedido de "${cliente}"`;
    const urlWA = `https://wa.me/5493534247019?text=${encodeURIComponent(msgWA)}`;
    window.open(urlWA, '_blank');

    limpiarFormulario();
    mostrarHistorial();
}

// ── Historial ─────────────────────────────────────────────────
function mostrarHistorial() {
    const contenedor = document.getElementById('listaPedidos');
    if (!contenedor) return;

    let historial = [];
    try { historial = JSON.parse(localStorage.getItem('famat_pedidos')) || []; } catch {}

    if (historial.length === 0) {
        contenedor.innerHTML = '<div class="mensaje">📭 Aún no hay pedidos enviados.</div>';
        return;
    }

    let html = `<table class="tabla-pedidos">
        <thead><tr>
            <th>Fecha envío</th>
            <th>Cliente</th>
            <th>Detalle</th>
            <th>Entrega</th>
            <th>Estado</th>
        </tr></thead><tbody>`;

    historial.forEach(p => {
        const prods = (p.productos || []).map(x => {
            const det = (x.kilos !== null && x.kilos > 0) ? `${x.kilos} kg` : `x${x.cantidad}`;
            return `${x.nombre} (${det})`;
        }).join('<br>');

        const liqs = (p.liquidos && p.liquidos.length > 0)
            ? p.liquidos.map(l => `${l.nombre} — ${l.litros} L`).join('<br>')
            : '';

        const detalle = [prods, liqs].filter(Boolean).join('<br><em style="color:#667eea">Líquidos:</em><br>');

        const etiquetas = {
            pendiente: '🕐 Pendiente',
            en_preparacion: '⚙️ En preparación',
            listo: '✅ Listo',
            entregado: '🚚 Entregado'
        };

        html += `<tr>
            <td>${p.fechaCreacion || p.fecha || ''}</td>
            <td><strong>${p.cliente}</strong></td>
            <td style="font-size:0.88em;">${detalle}${p.notas ? `<br><em>📝 ${p.notas}</em>` : ''}</td>
            <td>${p.entrega}</td>
            <td>${etiquetas[p.estado] || p.estado}</td>
        </tr>`;
    });

    html += '</tbody></table>';
    html += `<div class="resumen">
        <div class="resumen-item"><span>Total de pedidos enviados:</span><span>${historial.length}</span></div>
    </div>`;

    contenedor.innerHTML = html;
}
